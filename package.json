{
  "name": "lore",
  "displayName": "Lore — Enriched inline comments",
  "description": "Capture design decisions, architectural context, and technical trade-offs as rich markdown annotations stored directly in your repo.",
  "publisher": "annot8-lore",
  "version": "0.0.1",
  "keywords": [
    "annotations",
    "comments",
    "documentation",
    "architecture",
    "knowledge"
  ],
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "vscode": "^1.79.0"
  },
  "categories": [
    "Other",
    "Notebooks"
  ],
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:.lore.json"
  ],
  "main": "out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "lore.createEnrichedComment",
        "title": "Lore: Weave new Lore"
      },
      {
        "command": "lore.enableHighlights",
        "title": "Lore: Summon Highlights"
      },
      {
        "command": "lore.disableHighlights",
        "title": "Lore: Seal Highlights"
      },
      {
        "command": "lore.editComment",
        "title": "Lore: Patch the Lore"
      },
      {
        "command": "lore.previewMarkdown",
        "title": "Lore: View Lore Entry"
      },
      {
        "command": "lore.listAllEntries",
        "title": "Lore: Reveal all Entries"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "lore.editComment",
          "when": "false"
        },
        {
          "command": "lore.previewMarkdown",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "Lore",
      "properties": {
        "lore.highlightColor": {
          "type": "string",
          "default": "rgba(255, 255, 0, 0.2)",
          "markdownDescription": "Background color for highlighted annotated lines. Accepts any CSS color value, e.g. `rgba(255, 200, 0, 0.25)` or `#ffff0033`."
        },
        "lore.highlightOnStartup": {
          "type": "boolean",
          "default": false,
          "description": "Automatically enable highlights when a workspace with lore entries is opened."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.js",
    "compile": "tsc -p ./",
    "watch": "tsc -p ./ -w",
    "bundle": "node esbuild.js",
    "bundle:watch": "node esbuild.js --watch",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:integration": "tsc -p tsconfig.tests.json && node ./out/tests/runTest.js",
    "pretest": "tsc -p tsconfig.tests.json",
    "test": "node ./out/tests/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^9.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.79.0",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.4",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "typescript": "^5.0.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "marked": "^17.0.1",
    "uuid": "^13.0.0"
  }
}
